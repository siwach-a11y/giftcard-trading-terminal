// Personal E-Gift Card Trading Terminal — persistence schema.
// Deliberately contains no vendor/connector-specific tables: connectors are
// identified only by an opaque `connectorId` string supplied at runtime.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev, "debian-openssl-3.0.x" for the Cloud Run image
  // (mcr.microsoft.com/playwright:v1.48.0-jammy is Ubuntu 22.04 / OpenSSL 3.0).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SearchHistory {
  id         String   @id
  requestId  String   @unique
  product    String
  country    String?
  currency   String?
  faceValue  Float?
  quantity   Int?
  offerCount Int
  durationMs Int
  offersJson String
  createdAt  DateTime @default(now())
}

model ExecutionHistory {
  id             String    @id
  executionId    String    @unique
  connectorId    String
  offerId        String
  offerJson      String
  status         String
  attempt        Int
  maxAttempts    Int
  purchaseStatus String?
  voucherCode    String?
  error          String?
  startedAt      DateTime
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([connectorId])
}

model RoutingHistory {
  id              String   @id
  bestOfferId     String?
  bestConnectorId String?
  explanation     String
  rankedJson      String
  createdAt       DateTime @default(now())
}

model ConnectorHealth {
  id          String   @id @default(cuid())
  connectorId String   @unique
  state       String
  latencyMs   Int?
  message     String?
  checkedAt   DateTime
}

model Settings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
