{
  "name": "giftcard-trading-terminal",
  "version": "0.1.0",
  "private": true,
  "description": "Personal E-Gift Card / E-Voucher trading terminal. Single-operator procurement tool that compares gift card offers across connectors and executes purchases via browser automation. Not a marketplace, not a SaaS, no customers.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "build:static": "bash scripts/build-static-demo.sh",
    "deploy:pages": "PAGES_BASE_PATH=/giftcard-trading-terminal npm run build:static && gh-pages -d out --dotfiles"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "js-yaml": "^4.1.0",
    "next": "14.2.35",
    "playwright": "^1.48.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "gh-pages": "^6.1.1",
    "prisma": "^5.20.0",
    "typescript": "^5.6.3"
  }
}
